# LLM Configuration (DashScope)
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_API_KEY="your-dashscope-api-key"
LLM_MODEL="qwen3.5-flash"
VLM_MODEL="qwen3.5-flash"
EMBEDDING_MODEL="text-embedding-v4"
RERANK_MODEL="qwen3-vl-rerank"

# Tavily Search (optional)
TAVILY_API_KEY="your-tavily-api-key"

# Qdrant Vector Database (optional, defaults to localhost:6333)
QDRANT_HOST="localhost"
QDRANT_PORT="6333"

# PostgreSQL (optional, defaults to InMemorySaver)
DATABASE_URL="postgresql://postgres:password@localhost:5432/health_agent"
